[
  {
    "name": "send_email",
    "description": "Send an email. Use for the Outreach and Concierge agents. Args: to, subject, body.",
    "webhook": "/webhook/send-email",
    "parameters": {
      "type": "object",
      "properties": {
        "to": {"type": "string", "description": "recipient email address"},
        "subject": {"type": "string"},
        "body": {"type": "string"}
      },
      "required": ["to", "subject", "body"]
    }
  },
  {
    "name": "create_github_issue",
    "description": "Create an issue in a GitHub repo. Use for the Octopilot agent.",
    "webhook": "/webhook/github-issue",
    "parameters": {
      "type": "object",
      "properties": {
        "repo": {"type": "string", "description": "owner/repo"},
        "title": {"type": "string"},
        "body": {"type": "string"}
      },
      "required": ["repo", "title"]
    }
  },
  {
    "name": "scrape_url",
    "description": "Fetch and return the readable text of a web page. Use for Harvest and Scout.",
    "webhook": "/webhook/scrape",
    "parameters": {
      "type": "object",
      "properties": {"url": {"type": "string"}},
      "required": ["url"]
    }
  },
  {
    "name": "web_search",
    "description": "Search the web and return the top results. Use for Scout and Prospector.",
    "webhook": "/webhook/search",
    "parameters": {
      "type": "object",
      "properties": {"query": {"type": "string"}},
      "required": ["query"]
    }
  }
]
