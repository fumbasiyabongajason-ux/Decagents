# Copy this file to ".env" and fill it in. NEVER commit the real .env.
# ===========================================================================
# 1) LLM PROVIDER  (free + fast default: Groq)
# ===========================================================================

# --- Groq — free + very fast (Llama, etc.).  Key: console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-key
LLM_MODEL=llama-3.3-70b-versatile

# --- Google Gemini — biggest free tier, no card.  Key: aistudio.google.com
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-google-ai-studio-key
# LLM_MODEL=gemini-2.0-flash

# --- OpenRouter — many free models, one key.  Key: openrouter.ai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Anthropic / Claude (paid) — use INSTEAD of the LLM_* block above
# ANTHROPIC_API_KEY=sk-ant-...
# DECAGENT_MODEL=claude-opus-4-8

# ===========================================================================
# 2) AGENT TOOLS  (how agents take real actions — or leave off for chat-only)
# ===========================================================================

# --- n8n (free, self-hosted) — recommended ---
TOOLS_BACKEND=n8n
# EASIEST: one router workflow handles ALL tools (import n8n/decagent-router.starter.json):
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/decagent
# OR, one webhook per tool instead of the router:
# N8N_BASE_URL=https://your-n8n.example.com
# N8N_AUTH_HEADER=Bearer your-webhook-secret    # optional, if you protect your webhooks
# Tool list (names + params the agents see) lives in runtime/n8n_tools.json
# (copy runtime/n8n_tools.example.json)

# --- Composio (alternative) — set a key and delete the TOOLS_BACKEND line above ---
# COMPOSIO_API_KEY=

# ===========================================================================
# 3) CONSOLE OPTIONS
# ===========================================================================
DECAGENT_PASSWORD=          # set a password to lock your Console on a public URL
DECAGENT_MAX_TURNS=12
DECAGENT_PORT=8000
