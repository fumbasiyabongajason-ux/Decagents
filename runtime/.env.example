# Copy this file to ".env" and fill it in. NEVER commit the real .env.
# ===========================================================================
# 1) PICK A FREE LLM PROVIDER  (one block below — Gemini is enabled by default)
# ===========================================================================

# --- Google Gemini — best free tier, no card needed.  Key: aistudio.google.com
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=your-google-ai-studio-key
LLM_MODEL=gemini-2.0-flash

# --- Groq — free + very fast (Llama, etc.).  Key: console.groq.com
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your-groq-key
# LLM_MODEL=llama-3.3-70b-versatile

# --- OpenRouter — many free models, one key.  Key: openrouter.ai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- OpenAI (paid).  Key: platform.openai.com
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- Anthropic / Claude (paid) — use INSTEAD of the LLM_* block above
# ANTHROPIC_API_KEY=sk-ant-...
# DECAGENT_MODEL=claude-opus-4-8

# ===========================================================================
# 2) AGENT TOOLS (optional, needed for real actions like email/GitHub)
#    Get a key + connect apps at app.composio.dev
# ===========================================================================
COMPOSIO_API_KEY=

# ===========================================================================
# 3) CONSOLE OPTIONS
# ===========================================================================
DECAGENT_PASSWORD=          # set a password to lock your Console on a public URL
DECAGENT_MAX_TURNS=12
DECAGENT_PORT=8000
