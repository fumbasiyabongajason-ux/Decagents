# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx     # get from console.anthropic.com
COMPOSIO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx          # get from app.composio.dev

# --- Optional ---
DECAGENT_MODEL=claude-opus-4-8     # which model the agents run on
DECAGENT_MAX_TURNS=12              # max tool-use rounds per request
DECAGENT_PORT=8000                 # API server port

# --- Billing (only needed for the live subscription site, see billing/) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
