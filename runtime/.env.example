# Copy this file to ".env" and fill it in. NEVER commit the real .env.
# ===========================================================================
# 1) LLM PROVIDER  (free + fast default: Groq)
# ===========================================================================

# --- Cerebras — fastest inference, free tier, no card.  Key: cloud.cerebras.ai
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=your-cerebras-key
LLM_MODEL=llama-3.3-70b

# --- Groq — free + very fast (Llama, etc.).  Key: console.groq.com
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your-groq-key
# LLM_MODEL=llama-3.3-70b-versatile

# --- Google Gemini — biggest free tier, no card.  Key: aistudio.google.com
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-google-ai-studio-key
# LLM_MODEL=gemini-2.0-flash

# --- OpenRouter — many free models, one key.  Key: openrouter.ai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Anthropic / Claude (paid) — use INSTEAD of the LLM_* block above
# ANTHROPIC_API_KEY=sk-ant-...
# DECAGENT_MODEL=claude-opus-4-8

# ===========================================================================
# 2) AGENT TOOLS  (how agents take real actions — or leave off for chat-only)
# ===========================================================================

# Pick ONE backend below (or leave all off for chat-only).

# --- A) Pipedream Connect MCP — managed auth, thousands of apps (RECOMMENDED) ---
# The app auto-mints + refreshes the token from your client id/secret. Just set these
# (see docs/PIPEDREAM.md for where each comes from):
TOOLS_BACKEND=mcp
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=proj_xxxxx
PIPEDREAM_ENVIRONMENT=development        # 'development' is free; 'production' needs a paid plan
PIPEDREAM_EXTERNAL_USER_ID=me            # any id for yourself
MCP_APP_SLUGS=gmail,github,slack         # which apps to expose
# (MCP_SERVER_URL defaults to Pipedream's endpoint automatically when the above are set.)

# Zapier MCP instead? set TOOLS_BACKEND=mcp + your Zapier SSE URL, skip the PIPEDREAM_* vars:
# MCP_SERVER_URL=https://actions.zapier.com/mcp/<your-id>/sse
# MCP_HEADERS={"Authorization":"Bearer <if-needed>"}

# --- B) n8n (free, self-hosted) ---
# TOOLS_BACKEND=n8n
# N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/decagent   # import n8n/decagent-router.starter.json
# (tool list lives in runtime/n8n_tools.json — copy runtime/n8n_tools.example.json)

# --- C) Composio ---
# TOOLS_BACKEND=composio
# COMPOSIO_API_KEY=

# ===========================================================================
# 3) CONSOLE OPTIONS
# ===========================================================================
DECAGENT_PASSWORD=          # set a password to lock your Console on a public URL
DECAGENT_MAX_TURNS=12
DECAGENT_PORT=8000
